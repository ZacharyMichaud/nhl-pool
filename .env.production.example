# ── Render Environment Variables ──
# Copy these into Render's dashboard > Environment > Environment Variables

# Database (Neon.tech)
DATABASE_URL=jdbc:postgresql://ep-still-term-an03vr8e.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require
DB_USER=neondb_owner
DB_PASSWORD=RESET_AND_PASTE_NEW_PASSWORD_HERE

# Security
JWT_SECRET=GENERATE_A_RANDOM_32_CHAR_STRING
ADMIN_SECRET=PICK_YOUR_ADMIN_REGISTRATION_CODE

# Server
PORT=8080

# NHL API
NHL_API_SEASON=20252026

# CORS — set to your Vercel frontend URL after deploying
CORS_ORIGINS=https://YOUR_APP.vercel.app
